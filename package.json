{
  "name": "specs-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Public upstream workspace for the SiteSpecs CLI, analyzer core, and shared contracts",
  "packageManager": "pnpm@10.13.1",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "benchmark:tech": "npm run benchmark:tech --workspace @sitespecs/analyzer-core --silent",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "release:publish": "npm run release:validate && node ./tools/release/publish-release.mjs",
    "release:validate": "node ./tools/release/validate-release.mjs",
    "release:validate:dry-run": "node ./tools/release/validate-release.mjs --dry-run",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:webhook-contract": "turbo run test:webhook-contract"
  },
  "devDependencies": {
    "@changesets/config": "^3.1.3",
    "@changesets/cli": "^2.29.6",
    "@types/node": "^22.19.7",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
